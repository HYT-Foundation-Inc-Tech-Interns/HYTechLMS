{
  "name": "hyt-global-institute",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "firebase": "^12.16.0",
    "lucide-react": "^1.26.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^6.0.4",
    "autoprefixer": "^10.5.4",
    "postcss": "^8.5.22",
    "tailwindcss": "^3.3.5",
    "vite": "^8.1.5"
  },
  "scripts": {
    "dev": "vite",
    "dev:staging": "vite --mode staging",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:public": "playwright test tests/e2e/public.spec.js tests/e2e/accessibility.spec.js",
    "test:e2e:responsive": "playwright test tests/e2e/responsive.spec.js",
    "test:e2e:roles": "playwright test tests/e2e/roles.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "deploy:staging": "npm run build:staging && firebase deploy --only hosting --project staging",
    "deploy:production": "npm run build && firebase deploy --only hosting --project production"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
