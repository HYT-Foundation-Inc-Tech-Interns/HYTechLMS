rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPERS ====================

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Role from the caller's own users doc. exists() guard handles
    // first-login before the doc is created.
    function myRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none')
        : 'none';
    }

    function canUseLms() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', 'Inactive') == 'Active'
        && (
          request.auth.token.email_verified == true
          || myRole() in ['admin', 'trainer']
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('createdBy', '') == 'admin'
        );
    }

    function isAdmin()   { return canUseLms() && myRole() == 'admin'; }
    function isTrainer() { return canUseLms() && myRole() == 'trainer'; }

    // Role of an arbitrary user (used to restrict who a student may notify).
    function roleOf(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        ? get(/databases/$(database)/documents/users/$(uid)).data.get('role', 'none')
        : 'none';
    }

    // True when classes/{classId} exists.
    function classExists(classId) {
      return exists(/databases/$(database)/documents/classes/$(classId));
    }

    // Learners may only request enrollment in a class that is explicitly open.
    // This server-side check prevents a modified client from joining draft,
    // provisioning, archived, or otherwise inactive classes.
    function classAcceptsSelfEnrollment(classId) {
      return classExists(classId)
        && get(/databases/$(database)/documents/classes/$(classId))
          .data.get('status', '') in ['Active', 'active'];
    }

    // Global access policy (config/appSettings → access map). Falls back to an
    // empty map when the config doc is absent so defaults apply.
    function appAccess() {
      return exists(/databases/$(database)/documents/config/appSettings)
        ? get(/databases/$(database)/documents/config/appSettings).data.get('access', {})
        : {};
    }

    // Self-registration is allowed unless an admin has explicitly turned it off.
    function selfRegistrationAllowed() {
      return appAccess().get('allowSelfRegistration', true) != false;
    }

    // A self-joining trainee may create a 'pending' enrollment, or an 'active'
    // one only when admins have turned enrollment approval off.
    function selfEnrollStatusAllowed(status) {
      return status == 'pending'
        || (status == 'active' && appAccess().get('requireEnrollmentApproval', true) == false);
    }

    // True when caller may manage classes/{classId} content: the lead trainer
    // OR a co-trainer listed in coTrainerIds. Content writes (materials, modules,
    // topics, assignments, assessments, grading, enrollments) use this so co-
    // trainers get the same content powers as the lead. Managing co-trainers and
    // transferring ownership edit the class doc itself, which stays lead-only.
    function classTrainer(classId) {
      return canUseLms()
        && exists(/databases/$(database)/documents/classes/$(classId))
        && (
          get(/databases/$(database)/documents/classes/$(classId)).data.get('trainerId', '') == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/classes/$(classId)).data.get('coTrainerIds', [])
        );
    }

    function classMember(classId) {
      return canUseLms()
        && exists(/databases/$(database)/documents/classes/$(classId)/members/$(request.auth.uid));
    }

    // Keys added/removed/changed by an update.
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ==================== USERS ====================

    match /users/{uid} {
      // Staff need directory access for rosters and administration. Trainees
      // may read only their own account, preventing organization-wide email
      // and account enumeration.
      allow read: if isAdmin() || isTrainer() || isSelf(uid);

      // Self-signup may only create a plain Active student, and only while an
      // admin has left self-registration enabled.
      // Admin may create any user doc (Add User writes as admin).
      allow create: if isAdmin()
        || (isSelf(uid)
            && request.resource.data.get('role', '') == 'student'
            && request.resource.data.get('status', '') == 'Active'
            && selfRegistrationAllowed());

      // Owner edits profile but NEVER role or status.
      allow update: if isAdmin()
        || (isSelf(uid) && !changedKeys().hasAny(['role', 'status']));

      allow delete: if isAdmin();

      match /lmsExperience/{docId} {
        allow read, write: if isSelf(uid) || isAdmin();
      }

      // Sensitive PII (phone, address, birthDate) lives here so it is NOT
      // exposed by the org-wide `users` read. Only the owner and admins see it.
      match /private/{docId} {
        allow read, write: if isSelf(uid) || isAdmin();
      }

      match /calendarEvents/{eventId} {
        allow read, write: if isSelf(uid);
      }

      // Private per-user class card nickname/color. These preferences never
      // alter the shared class or another trainee's view.
      match /classPrefs/{classId} {
        allow read: if isSelf(uid);
        allow create, update: if isSelf(uid)
          && request.resource.data.keys().hasOnly(['nickname', 'color', 'updatedAt'])
          && request.resource.data.get('nickname', '') is string
          && request.resource.data.get('nickname', '').size() <= 100
          && request.resource.data.get('color', '') in [
            '',
            'from-blue-500 to-blue-700',
            'from-purple-500 to-purple-700',
            'from-pink-500 to-pink-700',
            'from-red-500 to-red-700',
            'from-orange-500 to-orange-700',
            'from-yellow-500 to-yellow-700',
            'from-green-500 to-green-700',
            'from-teal-500 to-teal-700',
            'from-cyan-500 to-cyan-700',
            'from-indigo-500 to-indigo-700'
          ];
        allow delete: if isSelf(uid);
      }
    }

    // ==================== USER SETTINGS ====================
    // Read by others for avatar display; write owner-only.
    match /userSettings/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow write: if isSelf(uid) || isAdmin();
    }

    // ==================== GLOBAL APP SETTINGS ====================
    // Single org-wide config doc (branding, access/registration policy,
    // notification toggles). Public read is required so pre-auth pages (the
    // branded landing/sign-in and the self-registration gate) can read it; the
    // contents are non-sensitive. Admin-only writes.
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==================== SECTORS ====================
    match /sectors/{sectorId} {
      allow read: if canUseLms();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ==================== COURSE TEMPLATES ====================
    match /courses/{courseId} {
      allow read: if canUseLms();
      allow create, update: if isAdmin();
      allow delete: if false;

      match /topics/{topicId} {
        allow read: if isAdmin() || isTrainer();
        allow write: if isAdmin();
      }

      match /materials/{materialId} {
        allow read: if isAdmin() || isTrainer();
        allow write: if isAdmin();
      }

      match /assignments/{assignmentId} {
        allow read: if isAdmin() || isTrainer();
        allow write: if isAdmin();

        match /{nested=**} {
          allow read, write: if false;
        }
      }

      match /assessments/{assessmentId} {
        allow read: if isAdmin() || isTrainer();
        allow write: if isAdmin();

        // Template answer keys are copied only by the Admin SDK. They are
        // never readable from a browser, including admin/trainer browsers.
        match /private/{privateId} {
          allow read, write: if false;
        }

        match /{nested=**} {
          allow read, write: if false;
        }
      }
    }

    // Sanitized enrollment directory. It intentionally excludes meetings,
    // internal activity, rosters, and other class-private fields.
    match /classDirectory/{classId} {
      allow read: if isAdmin()
        || isTrainer()
        || (canUseLms()
            && resource.data.get('status', '') in ['Active', 'active']);
      allow write: if false;
    }

    // ==================== CLASSES ====================
    match /classes/{classId} {
      allow read: if isAdmin() || isTrainer() || classMember(classId);

      allow create: if isAdmin()
        || (isTrainer() && request.resource.data.get('trainerId', '') == request.auth.uid);

      allow update: if isAdmin()
        || (canUseLms() && resource.data.get('trainerId', '') == request.auth.uid);
      // Trusted recursive deletion also removes subcollections/enrollments.
      allow delete: if false;

      match /members/{uid} {
        allow read: if isAdmin() || classTrainer(classId) || isSelf(uid);
        allow create, update: if isAdmin()
          || classTrainer(classId)
          || (isSelf(uid)
              && request.resource.data.get('studentId', '') == request.auth.uid
              && exists(/databases/$(database)/documents/enrollments/$(request.resource.data.get('enrollmentId', 'none')))
              && get(/databases/$(database)/documents/enrollments/$(request.resource.data.get('enrollmentId', 'none'))).data.get('studentId', '') == request.auth.uid
              && get(/databases/$(database)/documents/enrollments/$(request.resource.data.get('enrollmentId', 'none'))).data.get('classId', '') == classId
              && get(/databases/$(database)/documents/enrollments/$(request.resource.data.get('enrollmentId', 'none'))).data.get('status', '') in ['active', 'ongoing', 'completed']);
        allow delete: if isAdmin() || classTrainer(classId);
      }

      // ---- Content subcollections: authed read, owner-trainer write ----
      match /materials/{materialId} {
        allow read: if isAdmin() || classTrainer(classId) || classMember(classId);
        allow write: if isAdmin() || classTrainer(classId);
      }

      match /modules/{moduleId} {
        allow read: if isAdmin() || classTrainer(classId) || classMember(classId);
        allow write: if isAdmin() || classTrainer(classId);

        match /materials/{materialId} {
          allow read: if isAdmin() || classTrainer(classId) || classMember(classId);
          allow write: if isAdmin() || classTrainer(classId);
        }
      }

      match /topics/{topicId} {
        allow read: if isAdmin() || classTrainer(classId) || classMember(classId);
        allow write: if isAdmin() || classTrainer(classId);
      }

      match /assignments/{assignmentId} {
        allow read: if isAdmin() || classTrainer(classId) || classMember(classId);
        allow write: if isAdmin() || classTrainer(classId);

        // Student deliverable submissions. Doc id = studentId.
        match /submissions/{studentId} {
          allow read: if isAdmin() || classTrainer(classId) || isSelf(studentId);

          // Student may submit only as themselves, and may never write grade fields.
          allow create: if isSelf(studentId)
            && request.resource.data.get('studentId', '') == request.auth.uid
            && !request.resource.data.keys().hasAny(['grade', 'feedback', 'gradedBy', 'gradedAt']);

          // Trainer/admin grade; student may update their own work but not grade fields.
          allow update: if isAdmin()
            || classTrainer(classId)
            || (isSelf(studentId)
                && !changedKeys().hasAny(['grade', 'feedback', 'gradedBy', 'gradedAt']));

          allow delete: if isAdmin() || classTrainer(classId);
        }
      }

      // Announcements: trainer/admin AND the author (students post to the
      // class feed and then update their own post to attach a file).
      match /announcements/{announcementId} {
        allow read: if isAdmin() || classTrainer(classId) || classMember(classId);
        allow create: if isAdmin()
          || classTrainer(classId)
          || (classMember(classId) && request.resource.data.get('authorId', '') == request.auth.uid);
        allow update: if isAdmin()
          || classTrainer(classId)
          || (canUseLms() && resource.data.get('authorId', '') == request.auth.uid);
        allow delete: if isAdmin()
          || classTrainer(classId)
          || (canUseLms() && resource.data.get('authorId', '') == request.auth.uid);

        match /comments/{commentId} {
          allow read: if isAdmin() || classTrainer(classId) || classMember(classId);
          allow create: if classMember(classId)
            && request.resource.data.get('authorId', '') == request.auth.uid;
          allow update: if false;
          allow delete: if isAdmin()
            || classTrainer(classId)
            || (canUseLms() && resource.data.get('authorId', '') == request.auth.uid);
        }
      }

      // Student engagement events (class opened/closed, alt-tab during an
      // assessment). A student writes only their own events; staff read all.
      match /activity/{eventId} {
        allow read: if isAdmin()
          || classTrainer(classId)
          || (canUseLms() && resource.data.get('studentId', '') == request.auth.uid);
        allow create: if canUseLms()
          && request.resource.data.get('studentId', '') == request.auth.uid;
        // Events are immutable; staff/admin may clean up.
        allow update: if false;
        allow delete: if isAdmin() || classTrainer(classId);
      }

      match /assessments/{assessmentId} {
        allow read: if isAdmin() || classTrainer(classId) || classMember(classId);
        allow create, update: if isAdmin() || classTrainer(classId);
        // Recursive deletion is performed by a trusted Cloud Function so
        // private answer keys and attempts cannot be orphaned.
        allow delete: if false;

        match /private/{privateId} {
          allow read, write: if isAdmin() || classTrainer(classId);
        }

        match /attempts/{attemptId} {
          allow read: if isAdmin()
            || classTrainer(classId)
            || (canUseLms() && resource.data.get('studentId', '') == request.auth.uid);
          // Attempts are created only by the trusted grading Cloud Function.
          allow create: if false;
          // Attempts are immutable (anti-tampering). Admin may delete.
          allow update: if false;
          allow delete: if isAdmin();
        }
      }
    }

    // ==================== ENROLLMENTS ====================
    // Students see only their own enrollments; a class trainer sees their
    // class roster and admins see all.
    match /enrollments/{enrollmentId} {
      allow read: if isAdmin()
        || (canUseLms() && resource.data.get('studentId', '') == request.auth.uid)
        || (isTrainer() && classTrainer(resource.data.get('classId', 'none')));

      // A student self-joining by class code creates a PENDING enrollment that
      // the class trainer must approve before it becomes active. Admins and
      // trainers may still create active enrollments directly.
      allow create: if isAdmin()
        || (canUseLms()
            && enrollmentId == request.resource.data.get('classId', '') + '_' + request.auth.uid
            && request.resource.data.get('studentId', '') == request.auth.uid
            && selfEnrollStatusAllowed(request.resource.data.get('status', ''))
            && classAcceptsSelfEnrollment(request.resource.data.get('classId', 'none')))
        || (isTrainer() && request.resource.data.get('trainerId', '') == request.auth.uid)
        // A co-trainer adds a trainee: the enrollment's trainerId is the LEAD,
        // so authorize by class membership instead of the trainerId field.
        || (isTrainer() && classTrainer(request.resource.data.get('classId', 'none')));

      // Trainer of record / class trainer / admin change status+progress.
      // Student may change ONLY their own progress field.
      allow update: if isAdmin()
        || (canUseLms() && resource.data.get('trainerId', '') == request.auth.uid)
        || (isTrainer() && classTrainer(resource.data.get('classId', 'none')))
        || (canUseLms()
            && resource.data.get('studentId', '') == request.auth.uid
            && changedKeys().hasOnly(['progress', 'updatedAt']));

      allow delete: if isAdmin()
        || (canUseLms() && resource.data.get('trainerId', '') == request.auth.uid)
        || (isTrainer() && classTrainer(resource.data.get('classId', 'none')));
    }

    // ==================== ID CARD REQUESTS ====================
    // Admin approves/rejects/completes directly (trainer is not involved).
    match /idRequests/{id} {
      allow read: if isAdmin()
        || (canUseLms() && resource.data.get('studentId', '') == request.auth.uid);

      // Student raises their own ticket, always starting 'pending'.
      allow create: if canUseLms()
        && request.resource.data.get('studentId', '') == request.auth.uid
        && request.resource.data.get('status', '') == 'pending';

      // Only admin changes status. Student cannot update.
      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // ==================== INCIDENT FORMS ====================
    match /incidentForms/{id} {
      // Staff (admin/trainer) see all; a filer sees their own.
      allow read: if isAdmin() || isTrainer()
        || (canUseLms() && resource.data.get('filedBy', '') == request.auth.uid);

      allow create: if canUseLms()
        && request.resource.data.get('filedBy', '') == request.auth.uid;

      // Status handling by staff only.
      allow update: if isAdmin() || isTrainer();

      allow delete: if isAdmin();
    }

    // ==================== NOTIFICATIONS ====================
    match /notifications/{notificationId} {
      // Sender must identify themselves. Staff (admin/trainer) may notify
      // anyone; a student may only notify staff (prevents a student from
      // blasting phishing notifications to every other student).
      allow create: if canUseLms()
        && request.resource.data.get('fromUid', '') == request.auth.uid
        && (isAdmin()
            || isTrainer()
            || roleOf(request.resource.data.get('toUid', '')) in ['trainer', 'admin']);

      allow read: if isAdmin()
        || (canUseLms() && resource.data.get('toUid', '') == request.auth.uid);

      // Recipient may only flip the unread flag.
      allow update: if canUseLms()
        && resource.data.get('toUid', '') == request.auth.uid
        && changedKeys().hasOnly(['unread']);

      allow delete: if isAdmin()
        || (canUseLms() && resource.data.get('toUid', '') == request.auth.uid);
    }

    // ==================== ACTIVITY LOGS ====================
    // Append-only audit trail. Admin bypass on create covers legacy
    // logActivity('admin', ...) calls.
    match /activityLogs/{logId} {
      allow create: if isAdmin()
        || (canUseLms() && request.resource.data.get('userId', '') == request.auth.uid)
        || (isSelf(request.resource.data.get('userId', ''))
            && request.resource.data.get('action', '') == 'user_signup');
      allow read: if isAdmin()
        || (canUseLms() && resource.data.get('userId', '') == request.auth.uid);
      // Logs are immutable; admins may purge them for maintenance/history reset.
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ==================== STUDENT PROGRESS ====================
    match /students/{studentId}/progress/{classId} {
      allow read: if isAdmin() || isTrainer() || isSelf(studentId);
      allow write: if isAdmin() || isSelf(studentId) || classTrainer(classId);
    }

    // Unmatched paths are denied by default.
  }
}
