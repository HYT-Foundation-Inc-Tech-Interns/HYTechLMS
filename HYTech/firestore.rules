rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for authentication and role-based access
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'Admin';
    }
    
    function isTrainer() {
      return isAuthenticated() && getUserRole() == 'Trainer';
    }
    
    function isStudent() {
      return isAuthenticated() && getUserRole() == 'Student';
    }
    
    function isSupervisor() {
      return isAuthenticated() && getUserRole() == 'Supervisor';
    }
    
    function isOwnUser(uid) {
      return request.auth.uid == uid;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserRole() == role;
    }
    
    // Allow supervisors and admins to view any user
    function canViewUser(targetUserId) {
      return isOwnUser(targetUserId) || isAdmin() || isSupervisor();
    }
    
    // Users collection - Personal user data
    match /users/{userId} {
      // Students can read their own profile
      // Trainers can read their own profile + other trainers
      // Supervisors can read all users (for student/trainer management)
      // Admins can read all users
      allow read: if isAuthenticated() && (
                     isOwnUser(userId) ||                                    // Own profile
                     (isTrainer() && hasRole('Trainer')) ||                 // Trainers see trainers
                     (isSupervisor()) ||                                     // Supervisors see all
                     (isAdmin())                                             // Admins see all
                  );
      
      // Users can update their own profile (except role/email/protected fields)
      allow update: if isOwnUser(userId) && 
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email', 'createdAt', 'status']);
      
      // Only Admins can create users
      allow create: if isAdmin() &&
                       request.resource.data.role is string &&
                       request.resource.data.email is string &&
                       request.resource.data.displayName is string;
      
      // Only Admins can delete users
      allow delete: if isAdmin();
      
      // Admins and Supervisors can update user roles, emails, and status
      allow update: if (isAdmin() || isSupervisor()) && 
                       request.resource.data.role is string && 
                       request.resource.data.email is string;
    }
    
    // Sectors collection - Sector/Category management
    match /sectors/{sectorId} {
      // All authenticated users can read sectors
      allow read: if isAuthenticated();
      
      // Only Admins and Supervisors can create/update/delete sectors
      allow create, update: if (isAdmin() || isSupervisor()) &&
                               request.resource.data.name is string &&
                               request.resource.data.description is string &&
                               request.resource.data.status is string;
      
      allow delete: if isAdmin() || isSupervisor();
    }
    
    // Settings collection - User and system settings
    match /settings/{settingId} {
      // All authenticated users can read public settings
      allow read: if isAuthenticated();
      
      // Users can update their own settings
      // Admins can update system-wide settings
      allow update: if (isOwnUser(settingId) && settingId.matches('^user_.*')) ||
                       (isAdmin() && settingId.matches('^system_.*'));
      
      // Only Admins can create/delete settings
      allow create, delete: if isAdmin();
    }
    
    // UserActivities collection - Track user activities
    match /userActivities/{activityId} {
      // Users can read their own activities
      // Supervisors and Admins can read all activities
      allow read: if isAuthenticated() && (
                     isAdmin() ||
                     isSupervisor() ||
                     isStudent()
                  );
      
      // Any authenticated user can log their activity
      allow create: if isAuthenticated() &&
                       request.resource.data.userId is string &&
                       request.resource.data.activityType is string &&
                       request.resource.data.timestamp is timestamp;
      
      allow delete: if isAdmin();
    }
    
    // Calendar collection - Class schedules and events
    match /calendar/{eventId} {
      // All authenticated users can read calendar events
      allow read: if isAuthenticated();
      
      // Trainers can create calendar events for their courses
      allow create: if isTrainer() &&
                       request.resource.data.courseId is string &&
                       request.resource.data.trainerUid == request.auth.uid &&
                       request.resource.data.eventDate is timestamp;
      
      // Trainers can update/delete their own events
      // Supervisors and Admins can manage any event
      allow update, delete: if (isTrainer() && resource.data.trainerUid == request.auth.uid) ||
                               isSupervisor() ||
                               isAdmin();
    }
    
    // Courses collection - Course management
    match /courses/{courseId} {
      // Authenticated users can read courses
      // Students can see all courses (for enrollment options) - restrict via app if needed
      // Trainers can see all courses
      // Supervisors and Admins can see all courses
      allow read: if isAuthenticated();
      
      // Trainers can create courses in their sector
      allow create: if isTrainer() &&
                       request.resource.data.name is string &&
                       request.resource.data.trainerUid == request.auth.uid &&
                       request.resource.data.sectorId is string &&
                       request.resource.data.status is string;
      
      // Trainers can update/delete their own courses
      // Supervisors can update/delete any course (for management)
      // Admins can update/delete any course
      allow update: if (isTrainer() && resource.data.trainerUid == request.auth.uid) ||
                       isSupervisor() ||
                       isAdmin();
      
      allow delete: if (isTrainer() && resource.data.trainerUid == request.auth.uid) ||
                       isSupervisor() ||
                       isAdmin();
    }
    
    // Tasks collection - Task management
    match /tasks/{taskId} {
      // All authenticated users can read tasks (students see their enrolled courses' tasks)
      allow read: if isAuthenticated();
      
      // Trainers can create tasks for their courses
      allow create: if isTrainer() &&
                       request.resource.data.courseId is string &&
                       request.resource.data.title is string &&
                       request.resource.data.trainerUid == request.auth.uid;
      
      // Trainers can update/delete their own tasks
      // Supervisors and Admins can manage any task
      allow update: if (isTrainer() && resource.data.trainerUid == request.auth.uid) ||
                       isSupervisor() ||
                       isAdmin() ||
                       (isStudent() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentStatus', 'completedAt', 'submissionDate']));
      
      allow delete: if (isTrainer() && resource.data.trainerUid == request.auth.uid) ||
                       isSupervisor() ||
                       isAdmin();
    }
    
    // StudentEnrollments collection - Track student course enrollments
    match /studentEnrollments/{enrollmentId} {
      // Students can read their own enrollments
      // Trainers can read enrollments for their courses (student list)
      // Supervisors and Admins can read all enrollments
      allow read: if isAuthenticated() && (
                     isStudent() ||                                          // Students see their own
                     isSupervisor() ||                                       // Supervisors see all
                     isAdmin() ||                                            // Admins see all
                     (isTrainer() && resource.data.get('courseId') != null)  // Trainers see their course enrollments
                  );
      
      // Supervisors and Admins can create enrollments
      allow create: if (isAdmin() || isSupervisor()) &&
                       request.resource.data.studentUid is string &&
                       request.resource.data.courseId is string &&
                       request.resource.data.enrollmentDate is timestamp &&
                       request.resource.data.status is string;
      
      // Supervisors and Admins can update enrollment status
      allow update: if (isAdmin() || isSupervisor()) &&
                       request.resource.data.studentUid is string &&
                       request.resource.data.courseId is string;
      
      // Admins and Supervisors can delete enrollments
      allow delete: if isAdmin() || isSupervisor();
    }
    
    // Certificates collection - Student certificates
    match /certificates/{certificateId} {
      // Students can read their own certificates
      allow read: if isAuthenticated() &&
                     (isOwnUser(resource.data.studentUid) || isAdmin() || isSupervisor());
      
      // Admins and Supervisors can create/update/delete certificates
      allow create, update, delete: if (isAdmin() || isSupervisor()) &&
                                       request.resource.data.studentUid is string &&
                                       request.resource.data.certificateName is string &&
                                       request.resource.data.issuedDate is timestamp;
    }
    
    // Reports collection - Supervisor reports and analytics
    match /reports/{reportId} {
      // Only Supervisors and Admins can read reports
      allow read: if isSupervisor() || isAdmin();
      
      // Supervisors and Admins can create/update reports
      allow create, update: if (isSupervisor() || isAdmin()) &&
                               request.resource.data.reportType is string &&
                               request.resource.data.createdBy is string &&
                               request.resource.data.createdDate is timestamp;
      
      // Only Admins can delete reports
      allow delete: if isAdmin();
    }
    
    // StudentProgress collection - Track student progress in courses
    match /studentProgress/{progressId} {
      // Students can read their own progress
      // Trainers can read progress for their course students
      // Supervisors and Admins can read all progress
      allow read: if isAuthenticated() && (
                     isStudent() ||
                     isSupervisor() ||
                     isAdmin() ||
                     isTrainer()
                  );
      
      // System and tracked updates for student progress
      allow create, update: if isAuthenticated() &&
                               request.resource.data.studentUid is string &&
                               request.resource.data.courseId is string;
      
      // Only Admins can delete progress records
      allow delete: if isAdmin();
    }
    
    // ArchivedCourses collection - Track archived courses for students
    match /archivedCourses/{archivedId} {
      // Students can read their archived courses
      // Supervisors and Admins can read all archived courses
      allow read: if isAuthenticated() && (
                     isStudent() ||
                     isSupervisor() ||
                     isAdmin()
                  );
      
      // Supervisors and Admins can archive courses
      allow create: if (isSupervisor() || isAdmin()) &&
                       request.resource.data.courseId is string &&
                       request.resource.data.studentUid is string &&
                       request.resource.data.archivedDate is timestamp;
      
      allow delete: if isAdmin();
    }
    
    // SystemLogs collection - System activity logs (Admin and Supervisor only)
    match /systemLogs/{logId} {
      // Only Admins and Supervisors can read logs (for auditing)
      allow read: if isAdmin() || isSupervisor();
      
      // Any authenticated user can create logs (activity tracking)
      allow create: if isAuthenticated() &&
                       request.resource.data.action is string &&
                       request.resource.data.userId is string &&
                       request.resource.data.timestamp is timestamp &&
                       request.resource.data.description is string;
      
      // Only Admins can delete logs
      allow delete: if isAdmin();
      
      // Logs should never be updated once created
      allow update: if false;
    }
    
    // Notifications collection - User notifications and alerts
    match /notifications/{notificationId} {
      // Users can read their own notifications
      // Admins can read all notifications
      allow read: if isAuthenticated() && (
                     resource.data.userId == request.auth.uid ||
                     isAdmin()
                  );
      
      // Authenticated users can create notifications
      allow create: if isAuthenticated() &&
                       request.resource.data.userId is string &&
                       request.resource.data.message is string &&
                       request.resource.data.createdAt is timestamp &&
                       request.resource.data.type is string;
      
      // Users can update their own notifications (mark as read, etc)
      allow update: if resource.data.userId == request.auth.uid ||
                       isAdmin();
      
      // Only Admins can delete notifications
      allow delete: if isAdmin();
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
